generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

enum AutomationType {
  TITLE
  DESCRIPTION
  ALT_TEXT
  SEO_DESCRIPTION
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model BusinessRuleset {
  id                           String   @id @default(cuid())

  shop                         String   @unique

  productScan                  Boolean?  @default(false)
  productNameRule              String?
  productDescriptionRule       String?
  productImageRule             String?
  productVariantRule           String?
  productTagRule               String?
  productAltImageRule          String?


  titleOptimize                Boolean?  @default(true)
  descriptionOptimize          Boolean?  @default(true)
  seoOptimize                  Boolean?  @default(true)
  altTextOptimize              Boolean?  @default(true)
  keywords                     String?

  minTitleLength               Int      @default(20)
  maxTitleLength               Int      @default(70)

  productDescriptionTemplate   String?

  minDescriptionLength         Int      @default(120)
  maxDescriptionLength         Int      @default(300)

  maxAltDescLength             Int      @default(30)

  minImages                    Int      @default(1)
  requiresAltText              Boolean  @default(true)

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model Analytics{
  id                           String   @id @default(cuid())

  shop                         String   @unique
  totalOptimizations           Int      @default(0)
  totalProducts                Int      @default(0)
  seoScore                     Float    @default(0.0)
}

model Product {
  id                String   @id @default(cuid())
  shop              String
  shopifyProductId  String
  optimized         Boolean  @default(false)
  title             String
  description       String?
  seoDescription    String?
  analyses          SeoAnalysis[]
  media             ProductMedia[]
  optimizations     Optimization[]
  @@unique([shop, shopifyProductId])
}

model ProductContext {
  id                String   @id @default(cuid())
  shop              String
  shopifyProductId  String
  title             String
  description       String?
  seoDescription    String?
  media             ProductMediaContext[]
  @@unique([shop, shopifyProductId])
}


model ProductMedia {
  id          String   @id @default(cuid())
  productId String
  product Product @relation(fields: [productId], references: [id],onDelete: Cascade)
  shopifyMediaId  String?
  url         String
  altText     String?

  createdAt   DateTime @default(now())
}

model ProductMediaContext {
  id          String   @id @default(cuid())
  productId String
  product ProductContext @relation(fields: [productId], references: [id],onDelete: Cascade)
  shopifyMediaId  String?
  url         String?
  altText     String?

  createdAt   DateTime @default(now())
}

model Plan {
  id          String   @id @default(cuid())

  name        String   @unique
  price       Float    @default(0.0)

  monthlyOptimizationLimit  Int      @default(50)
  automationsAllowed        Boolean  @default(false)
  maxAutomationRules        Int      @default(0)

  createdAt   DateTime @default(now())

  subscriptions ShopSubscription[]   // ← add this
}

model ShopSubscription {
  id          String   @id @default(cuid())

  shop        String   @unique

  planName    String   @default("free")
  nextPlanName String?
  shopifySubscriptionId     String?
  shopifyConfirmationUrl    String?

  status      String   @default("pending")
  
  billingCycleStart DateTime @default(now())
  billingCycleEnd   DateTime?

  optimizationsUsedThisCycle  Int  @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan        Plan     @relation(fields: [planName], references: [name])
}

model Optimization {
  id        String   @id @default(cuid())
  shop      String
  productId String @unique
  status    String
  createdAt DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AutomationSettings {
  id String @id @default(cuid())

  shop String @unique

  enabled Boolean @default(false)

  autoApprove Boolean @default(false)

  optimizeTitle Boolean @default(false)
  optimizeDescription Boolean @default(false)
  optimizeAltText Boolean @default(false)
  optimizeSeo Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationRule {
  id String @id @default(cuid())

  shop String
  name String @default("Product Optimization")

  enable Boolean @default(true)

  optimizeTitle Boolean @default(false)
  optimizeDescription Boolean @default(false)
  optimizeAltText Boolean @default(false)
  optimizeSeo Boolean @default(false)

  createdAt DateTime @default(now())

  runs AutomationRun[]
}

model AutomationRun {
  id String @id @default(cuid())

  shop String
  productId String
  ruleId String

  status String @default("pending") 
  // pending | running | completed | failed

  startedAt DateTime?
  completedAt DateTime?

  rule AutomationRule @relation(fields: [ruleId], references: [id])

  results AutomationResult[]

  createdAt DateTime @default(now())
}

model AutomationResult {
  id String @id @default(cuid())

  runId String
  type AutomationType
  productId String
  originalValue String?
  optimizedValue String?

  approved Boolean @default(false)

  createdAt DateTime @default(now())

  run AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model SeoAnalysis {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id],onDelete: Cascade)

  score       Int
  completeness Int

  createdAt   DateTime @default(now())
}